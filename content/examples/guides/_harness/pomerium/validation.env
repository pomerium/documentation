# Shared validation-only Pomerium settings, injected into every guide fixture via
# `env_file:` so each guide's config file is routes-only. This swaps the guide's
# reader-facing hosted authenticate for the in-network Keycloak. Test-only values;
# never use these anywhere real.
ADDRESS=:443
AUTHENTICATE_SERVICE_URL=https://authenticate.localhost.pomerium.io
IDP_PROVIDER=oidc
IDP_PROVIDER_URL=http://keycloak.localhost.pomerium.io:8080/realms/pomerium-e2e
IDP_CLIENT_ID=pomerium
IDP_CLIENT_SECRET=pomerium-e2e-secret
IDP_SCOPES=openid,profile,email,groups
CERTIFICATE_FILE=/certs/pomerium.crt
CERTIFICATE_KEY_FILE=/certs/pomerium.key
COOKIE_SECRET=dj5y7E03ULP9YebCgHNIXmxWnWfYlVXCgwbm9IEdysI=
SHARED_SECRET=0CdEkgO02jgxmgSC2AdkqIbFELAN4CGw0v0RY85xNr4=
SIGNING_
LOG_LEVEL=info
